#################################
#
# Microservice Config file for Microservice Makefile
#
#################################

#################################
# Attributes
#################################
# uSERVICE_NAME must match the "Microservice Unique ID" of the Mircoservice defined in "Microservice Store".
uSERVICE_NAME=AWSIoT
uSERVICE_UID=AWSIOT
uSERVICE_VERSION_STR="1.0"
uSERVICE_CPU_CORE=CortexM4

uSERVICE_MAINSTACK_SIZE=0x800

#################################
# Build Entities
#################################
uSERVICE_CFLAGS=\
	-O \
	-DMQTT_DO_NOT_USE_CUSTOM_CONFIG=1 \
	-DCFG_ENABLE_AWS_LOGS=0

uSERVICE_LDFLAGS= \
	--specs=nano.specs --specs=nosys.specs -fno-section-anchors

uSERVICE_SOURCE_FILES= \
		Source/main.c \
		Libs/aws-iot-device-sdk-embedded-C/libraries/standard/coreMQTT/source/core_mqtt.c \
		Libs/aws-iot-device-sdk-embedded-C/libraries/standard/coreMQTT/source/core_mqtt_serializer.c \
		Libs/aws-iot-device-sdk-embedded-C/libraries/standard/coreMQTT/source/core_mqtt_state.c

uSERVICE_INCLUDE_DIRS= \
	-IInclude \
	-ILibs \
	-ILibs/aws-iot-device-sdk-embedded-C/libraries/standard/coreMQTT/source/include \
	-ILibs/aws-iot-device-sdk-embedded-C/libraries/standard/coreMQTT/source/interface

#################################
# GCC Entities
#################################
uSERVICE_TOOLCHAIN_GCC_PATH="C:/Program Files (x86)/GNU Arm Embedded Toolchain/10 2021.10/bin/"

# [OPTIONAL] CUSTOM LD PATH FOR MICROSERVICE
# uSERVICE_GCC_LD_PATH=<NOT_SET>
